# Etherscan V2 API key (one key works for all chains)
# Get one free at: https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Chain ID
# 84532 = Base Sepolia (testnet)
# 8453  = Base Mainnet
CHAIN_ID=84532

# Your deployed TokenFactory address (fill after deployment)
NEXT_PUBLIC_FACTORY_ADDRESS=0x...

# RPC URL for reading factory contract
RPC_URL=https://sepolia.base.org
